GROQ_API_KEY=your_groq_key_here
GROQ_FAST_MODEL=llama-3.3-70b-versatile
GROQ_REASONING_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=800
DATABASE_URL=postgresql://agent_user:yourpassword@localhost:5432/agent_db
ASYNC_DATABASE_URL=postgresql+asyncpg://agent_user:yourpassword@localhost:5432/agent_db
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=google-agent
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=google-agent
GOOGLE_CREDENTIALS_PATH=./credentials.json
# Optional legacy JSON fallback for local development only. Production uses
# encrypted, request-scoped OAuth credentials stored per user in PostgreSQL.
GOOGLE_TOKEN_JSON=
# Web OAuth client JSON (store as a secret in Railway; never commit the file)
GOOGLE_OAUTH_CLIENT_JSON=
GOOGLE_OAUTH_CLIENT_PATH=./google-oauth-web.json
FRONTEND_URL=http://localhost:3000
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
ALLOW_DEV_AUTH=false
JWT_SECRET_KEY=change-this-in-production-use-256-bit-random-string
JWT_ALGORITHM=HS256
OAUTH_ENCRYPTION_KEYS=
ADMIN_EMAILS=achintyat256@gmail.com
RAILWAY_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
NEON_DATABASE_URL=
OLLAMA_HOST=http://localhost:11434
DURABLE_RUNS_ENABLED=true
EMBEDDED_WORKER_ENABLED=true
LEGACY_CHAT_ENABLED=true
OKF_ENABLED=true
GOVERNED_IMPROVEMENTS_ENABLED=true
WORKER_POLL_SECONDS=1
WORKER_LEASE_SECONDS=120
RAW_TELEMETRY_RETENTION_DAYS=14
WORKFLOW_RETENTION_DAYS=90
AGGREGATE_RETENTION_DAYS=365
ADMIN_NOTIFICATION_EMAIL=
# Optional external publication adapters. Use a short-lived GitHub App installation
# token with Contents + Pull requests write access to this repository only.
GITHUB_PROPOSAL_REPOSITORY=agentic-ai-training/google-connector-app
GITHUB_PROPOSAL_TOKEN=
GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_PROMETHEUS_USERNAME=
GRAFANA_CLOUD_API_KEY=
DEPLOYMENT_VERSION=local
