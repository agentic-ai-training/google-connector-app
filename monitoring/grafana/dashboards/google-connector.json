  "panels":[
    {"type":"timeseries","title":"Requests / second","gridPos":{"h":8,"w":8,"x":0,"y":0},"targets":[{"expr":"sum(rate(agent_requests_total[5m]))","legendFormat":"requests"}]},
    {"type":"timeseries","title":"Request latency p95","gridPos":{"h":8,"w":8,"x":8,"y":0},"targets":[{"expr":"histogram_quantile(0.95, sum by (le) (rate(agent_request_latency_seconds_bucket[5m])))","legendFormat":"p95"}]},
    {"type":"timeseries","title":"LLM latency p95 by model","gridPos":{"h":8,"w":8,"x":16,"y":0},"targets":[{"expr":"histogram_quantile(0.95, sum by (le, model) (rate(agent_llm_latency_seconds_bucket[5m])))","legendFormat":"{{model}}"}]},
    {"type":"timeseries","title":"Tool latency p95","gridPos":{"h":8,"w":8,"x":0,"y":8},"targets":[{"expr":"histogram_quantile(0.95, sum by (le, tool_name) (rate(agent_tool_latency_seconds_bucket[5m])))","legendFormat":"{{tool_name}}"}]},
    {"type":"timeseries","title":"Tool errors","gridPos":{"h":8,"w":8,"x":8,"y":8},"targets":[{"expr":"sum by (tool_name) (rate(agent_tool_errors_total[5m]))","legendFormat":"{{tool_name}}"}]},
    {"type":"timeseries","title":"Empty retrieval context","gridPos":{"h":8,"w":8,"x":16,"y":8},"targets":[{"expr":"sum(rate(agent_empty_context_total[5m]))","legendFormat":"empty context"}]},
    {"type":"timeseries","title":"Durable run queue","gridPos":{"h":8,"w":8,"x":0,"y":16},"targets":[{"expr":"agent_run_queue_depth","legendFormat":"{{status}}"}]},
    {"type":"timeseries","title":"Ollama embedding latency p95","gridPos":{"h":8,"w":8,"x":8,"y":16},"targets":[{"expr":"histogram_quantile(0.95, sum by (le, operation) (rate(agent_embedding_duration_seconds_bucket{status=\"success\"}[5m])))","legendFormat":"{{operation}}"}]},
    {"type":"timeseries","title":"Ollama health and context overflow","gridPos":{"h":8,"w":8,"x":16,"y":16},"targets":[{"expr":"agent_ollama_model_loaded","legendFormat":"model loaded"},{"expr":"rate(agent_embedding_context_overflows_total[5m])","legendFormat":"overflow retries/s"}]},
    {"type":"timeseries","title":"Embedding and compensation queues","gridPos":{"h":8,"w":12,"x":0,"y":24},"targets":[{"expr":"agent_embedding_jobs","legendFormat":"embedding {{status}}"},{"expr":"agent_artifact_cleanup_requests","legendFormat":"cleanup {{status}}"}]},
